# nginx server block for TailorResume v2 — serves frontend + proxies /api/*.
# Place under /etc/nginx/sites-available/ and symlink into sites-enabled.

# Required by the WebSocket proxy below: maps to "upgrade" on a WS handshake and "" otherwise, so a
# normal REST request isn't told to upgrade. Must live at the http{} level — put it in nginx.conf,
# or in a file under conf.d/ (NOT inside the server block).
map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    server_name tailorresume-v2.duckdns.org;   # change as needed

    root /var/@TailorResume/frontend/dist;
    index index.html;

    # API → FastAPI. Also carries the board's live WebSocket (/api/interviews/live), so the
    # Upgrade/Connection headers below are REQUIRED — without them nginx strips the upgrade and the
    # socket never connects, silently dropping the board back to non-collaborative behaviour.
    location /api/ {
        proxy_pass http://127.0.0.1:8503;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection $connection_upgrade;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 300;
        client_max_body_size 25M;
    }

    # SPA fallback — all other routes serve index.html
    location / {
        try_files $uri $uri/ /index.html;
    }

    # Long cache for hashed assets
    location /assets/ {
        expires 1y;
        access_log off;
        add_header Cache-Control "public, immutable";
    }
}
