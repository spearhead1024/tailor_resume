# Web Push: the VAPID private key is a SECRET; subscriptions/state are per-deploy runtime data.
data/vapid_private.pem
data/push_subscriptions.json
data/notif_state.json
# JWT signing key — a SECRET; anyone with it can forge a valid session token for any user.
data/jwt_secret.txt

# ── Runtime data — NEVER commit ────────────────────────────────────────────
# A live SQLite DB committed mid-write is a torn snapshot (corrupt), and a pull
# overwrites the running DB/JSON underneath the process. Keep all runtime state
# out of git. (data/extension/ and data/guide/ are shipped assets and stay tracked.)
data/*.db
data/*.db.bak-*
data/interviews.json
data/interviews.json.*
data/avatars/
data/chat_images/
data/screenshots/
data/profile_resumes/
data/logs/
data/notif_state.json*
data/_dbrecovery/
data/notifications.json*
data/notif_snooze.json*
